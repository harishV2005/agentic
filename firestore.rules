rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - The user's unique ID
    //   - name: string (required, 1-100 chars) - Farmer's name
    //   - location: string (required, 1-200 chars) - Farm location
    //   - crops: string (required, 1-100 chars) - Primary crops
    //   - farmSize: string (required, 1-20 chars) - Size of the farm
    //   - farmUnit: string (required, 1-20 chars) - Unit of measurement
    //   - updatedAt: timestamp (optional) - Last update time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'name', 'location', 'crops', 'farmSize', 'farmUnit']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.location is string && data.location.size() > 0 && data.location.size() <= 200 &&
             data.crops is string && data.crops.size() > 0 && data.crops.size() <= 100 &&
             data.farmSize is string && data.farmSize.size() > 0 && data.farmSize.size() <= 20;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if false; // Profiles should not be deleted by users directly
    }
  }
}
